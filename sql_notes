SELECT * FROM database_name; 				=> databaseteki tüm verileri çekiyor.

SELECT table_column FROM database_name; 		=> şeklinde de veri çekilebiliyor.

SELECT DISTINCT table_column FROM database_name; 	=> Tekrar etmeyen verileri çekiyor

SELECT * FROM database WHERE table_column='x'; 	=> column'un x olduğu bütün verileri çekiyor ve komut AND / OR / NOT ile uzatılabilir

SELECT * FROM database ORDER BY column1 ASC|DESC;	=> ASCending veya DEScending orderda verileri çekiyor ve sıralıyor.

INSERT INTO Customers (CustomerName, ContactName, Address, City, PostalCode, Country) 
VALUES ('Cardinal', 'Tom B. Erichsen', 'Skagen 21', 'Stavanger', '4006', 'Norway');   => Tabloya veri ekliyor.

SELECT * FROM database WHERE table_column IS NULL|NOT NULL => Boş olan/olmayan rowları çeken bir komut.

UPDATE table_name
SET column1 = value1, column2 = value2,			=> Update a value 
WHERE condition;

DELETE FROM Customers;					=> Deletes the customers's all rows without deleting the table.
